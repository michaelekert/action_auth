<li class="mr-4">
  <%= link_to "Home", root_path, class: 'text-gray-700 hover:text-blue-600 transition' %>
</li>

<% if user_signed_in? %>
  <li class="mr-4">
    <%= link_to "Security", user_sessions_path, class: 'text-gray-700 hover:text-blue-600 transition' %>
  </li>
  <li class="mr-4">
    <%= button_to "Sign Out", user_session_path(current_session), method: :delete, class: 'text-gray-700 hover:text-blue-600 transition bg-transparent border-none p-0', form: { class: "inline" } %>
  </li>
<% else %>
  <li class="mr-4">
    <%= link_to "Sign In", new_user_session_path, class: 'text-gray-700 hover:text-blue-600 transition' %>
  </li>
  <li class="mr-4">
    <%= link_to "Sign Up", new_user_registration_path, class: 'text-gray-700 hover:text-blue-600 transition' %>
  </li>
<% end %>
