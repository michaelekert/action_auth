<div class="min-h-screen flex items-center justify-center bg-gray-100 px-4">
  <div class="w-full max-w-md bg-white shadow-lg rounded-lg p-8">
    <% if notice %>
      <p class="text-green-600 mb-4 text-sm"><%= notice %></p>
    <% end %>

    <% if alert %>
      <p class="text-red-600 mb-4 text-sm"><%= alert %></p>
    <% end %>

    <h1 class="text-2xl font-bold text-center mb-6">Sign in</h1>

    <%= form_with(url: sign_in_path, class: "space-y-4") do |form| %>
      <div>
        <%= form.label :email, class: "block font-medium text-gray-700 mb-1" %>
        <%= form.email_field :email, value: params[:email_hint], required: true, autofocus: true, autocomplete: "email",
                             class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :password, class: "block font-medium text-gray-700 mb-1" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password",
                                class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="flex items-center justify-between">
        <%= form.submit "Sign in", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded w-full" %>
      </div>
    <% end %>

    <div class="mt-6 space-y-2 text-center text-sm text-gray-600">
      <% if ActionAuth.configuration.magic_link_enabled? %>
        <%= link_to "Sign in with Magic Link", new_magics_requests_path, class: "text-blue-600 hover:underline block" %>
      <% end %>

      <% if ActionAuth.configuration.sms_auth_enabled? %>
        <%= link_to "Sign in with SMS", new_sms_auths_requests_path, class: "text-blue-600 hover:underline block" %>
      <% end %>

      <% if ActionAuth.configuration.passkey_only? %>
        <%= link_to "Sign in with Passkey", new_sessions_passkey_path, class: "text-blue-600 hover:underline block" %>
      <% end %>
    </div>

    <div class="mt-6 text-center text-sm text-gray-600 space-x-2">
      <%= link_to "Sign Up", sign_up_path, class: "text-blue-600 hover:underline" %>
      |
      <%= link_to "Reset Password", new_identity_password_reset_path, class: "text-blue-600 hover:underline" %>
      <% if ActionAuth.configuration.verify_email_on_sign_in %>
        |
        <%= link_to "Verify Email", identity_email_verification_path, class: "text-blue-600 hover:underline" %>
      <% end %>
    </div>
  </div>
</div>

